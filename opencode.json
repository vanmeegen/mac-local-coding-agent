{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3.6-coder": {
          "name": "Qwen3.6 27B (dense, reliable driver)",
          "tools": true
        },
        "qwen3.6:35b-a3b-coding-mxfp8": {
          "name": "Qwen3.6 35B-A3B (MoE, coding-tuned mxfp8, fast gear)",
          "tools": true
        }
      }
    },
    "omlx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "oMLX (local, experimental)",
      "options": {
        "baseURL": "http://localhost:8000/v1"
      },
      "models": {
        "unsloth-Qwen3.6-27B-UD-MLX-4bit": {
          "name": "Qwen3.6 27B MLX 4-bit (oMLX, experimental)",
          "tools": true
        }
      }
    }
  },
  "model": "ollama/qwen3.6-coder",
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "bun": "allow",
      "bun *": "allow",
      "bunx *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "node *": "allow",
      "tsc *": "allow",
      "vitest *": "allow",
      "eslint *": "allow",
      "prettier *": "allow",

      "ls *": "allow",
      "cat *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "pwd": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "which *": "allow",

      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git branch*": "allow",
      "git show*": "allow",
      "git add*": "allow",
      "git restore*": "allow",
      "git stash*": "allow",

      "git commit *": "ask",
      "git push *": "ask",

      "rm *": "ask",
      "curl *": "ask",
      "wget *": "ask",

      "rm -rf *": "deny",
      "sudo *": "deny",

      "*": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  }
}
